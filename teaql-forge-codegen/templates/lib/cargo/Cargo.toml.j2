[package]
name = "{{ rust_crate_name }}"
version = "{{ rust_crate_version }}"
edition = "2021"
description = "Generated TeaQL service crate for {{ name }}"
license = "MIT OR Apache-2.0"

[dependencies]
log = "0.4"
chrono = { version = "0.4", features = ["serde"] }
rust_decimal = { version = "1", features = ["serde"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
teaql-core = "{{ rust_teaql_dependency_version }}"
teaql-macros = "{{ rust_teaql_dependency_version }}"
teaql-runtime = "{{ rust_teaql_dependency_version }}"
teaql-sql = "{{ rust_teaql_dependency_version }}"
teaql-data-service = "{{ rust_teaql_dependency_version }}"
teaql-tool-core = "1.0.0"
{% if has_sql_provider %}{{ rust_sql_provider_dependency }}
{{ data_service }}
tokio = { version = "1", features = ["macros", "rt-multi-thread"] }{% endif %}
{% if domain.supportFullTextSearch %}
teaql-provider-meilisearch = "{{ rust_teaql_dependency_version }}"{% endif %}


