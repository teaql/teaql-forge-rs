{
    {% for item in objectDescriptor.rust_object_fields %}{{ checkRequiredDependency(objectDescriptor, item) }}{% if not loop.last %}{{ "" }}
{% endif %}{% endfor %}{{ "" }}

    let object_fields_count = 0{% for _field in objectDescriptor.rust_object_fields %}+ 1{% endfor %}{{ "" }};
    let base_fanout = std::cmp::max(1, object_fields_count) * 20;

    let fanout = match state.plan.scale {
        SampleDataScale::Tiny => base_fanout,
        SampleDataScale::Small => base_fanout * 5,
        SampleDataScale::Medium => base_fanout * 50,
    };

    log::info!("Generating sample data for {{ objectDescriptor.name }} (expected: {})...", fanout);

    for i in 0..fanout {
        let mut entity = Q::{{ objectDescriptor.rust_plural_name }}().purpose("Init Sample Data").new_entity(ctx);
        let mut used_refs = std::collections::HashSet::new();

        {% for item in objectDescriptor.rust_object_fields %}{{ fillObjectField(item) }}{% if not loop.last %}{{ "" }}
{% endif %}{% endfor %}{{ "" }}
        {% for item in objectDescriptor.rust_scalar_fields %}{{ fillScalarField(item) }}{% if not loop.last %}{{ "" }}
{% endif %}{% endfor %}{{ "" }}

        {% if objectDescriptor.reverse_relations %}let entity = {% endif %}entity.audit_as("Init Sample Data").save(ctx).await.map_err(|e| e.to_string())?;

        state.record_generated("{{ objectDescriptor.name }}");

        if i % 20 == 0 {
            log::info!("Generating {{ objectDescriptor.name }}: {}/{}", i, fanout);
        }

        {% if objectDescriptor.reverse_relations %}
        state.add_reference("{{ objectDescriptor.name }}", entity.id().into_u64());
        {% endif %}
    }

    log::info!("Successfully generated sample records for {{ objectDescriptor.name }}.");
    Ok(())
}
{% endif %}{% endmacro %}

{% macro fillScalarField(fieldDescriptor) %}
{% if fieldDescriptor.is_string %}
        entity.update_{{ fieldDescriptor.rust_storage_member_name }}(format!("{} {}", "{{ fieldDescriptor.default_sample_value }}", i + 1));
{% elif fieldDescriptor.is_number %}
        {
            let max_val: u64 = "{{ fieldDescriptor.default_sample_value }}".parse().unwrap_or(1000);
            let rand_val = (i as u64 + state.plan.seed) % max_val.max(1) + 1;
            entity.update_{{ fieldDescriptor.rust_storage_member_name }}(rand_val as i64);
        }
{% elif fieldDescriptor.is_date %}
        {
            let days = ((i as u64 + state.plan.seed) % (365 * 3)) as i64;
            let past = chrono::Utc::now().naive_utc() - chrono::Duration::try_days(days).unwrap_or_default();
            entity.update_{{ fieldDescriptor.rust_storage_member_name }}(past.format("%Y-%m-%d").to_string());
        }
{% elif fieldDescriptor.is_time %}
        {
            let days = ((i as u64 + state.plan.seed) % (365 * 3)) as i64;
            let past = chrono::Utc::now().naive_utc() - chrono::Duration::try_days(days).unwrap_or_default();
            entity.update_{{ fieldDescriptor.rust_storage_member_name }}(past.format("%Y-%m-%d %H:%M:%S").to_string());
        }
{% elif fieldDescriptor.is_boolean %}
        entity.update_{{ fieldDescriptor.rust_storage_member_name }}(i % 2 == 0);
{% endif %}{% endmacro %}

{% macro fillObjectField(fieldDescriptor) %}
        if let Some(ref_id) = state.pick_unused_id("{{ fieldDescriptor.field_type.refer.name }}", i as usize, &used_refs) {
            entity.update_{{ fieldDescriptor.rust_storage_member_name }}(ref_id);
            used_refs.insert(ref_id);
        } else {
            // Optional relation was missing in reference pool
        }{% endmacro %}

{% macro checkRequiredDependency(objectDescriptor, fieldDescriptor) %}
{% if fieldDescriptor.required %}
    if state.ids("{{ fieldDescriptor.field_type.refer.name }}").is_empty() {
        state.record_skipped("{{ objectDescriptor.name }}", "Required dependency {{ fieldDescriptor.field_type.refer.name }} is missing in reference pool".to_string());
        log::info!("Skipped generating {{ objectDescriptor.name }}: Required dependency {{ fieldDescriptor.field_type.refer.name }} is missing in reference pool.");
        return Ok(());
    }
{% endif %}{% endmacro %}
