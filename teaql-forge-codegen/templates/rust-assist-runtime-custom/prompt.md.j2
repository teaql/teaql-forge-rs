## 4. WebResponse — HTTP Response Builder

```rust
// From single entity
let response = WebResponse::from_entity(&task);

// From list with pagination
let response = WebResponse::from_smart_list(task_list);

// Error response
let response = WebResponse::fail("Invalid request");
```

