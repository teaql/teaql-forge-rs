<Domain name="AppDomain">
    <Entity name="User" table="users">
        <Field name="id" type="Id" required="true" unique="true"/>
        <Field name="name" type="String" required="true"/>
        <Field name="age" type="I32"/>
        <Relation name="company" target="Company" cardinality="ManyToOne"/>
    </Entity>
    <Entity name="Company" table="companies">
        <Field name="id" type="Id" required="true" unique="true"/>
        <Field name="name" type="String" required="true"/>
    </Entity>
</Domain>
